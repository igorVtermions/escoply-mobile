{
  "expo": {
    "name": "Escoply",
    "slug": "escoply-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-escoply.png",
    "scheme": "escoplymobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo-escoply.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-escoply.png",
        "backgroundColor": "#F8FAFC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.igorvtermions.escoplymobile"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "615c27da-1d8f-4b46-aafe-0e6621b4a18d"
      }
    }
  }
}
